{
	"name": "loresmith-ai",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/ofisk/loresmith-ai"
	},
	"engines": {
		"node": ">=20"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,jsonc,css,mjs}": [
			"npx @biomejs/biome check --write --no-errors-on-unmatched"
		],
		"*.{ts,tsx}": [
			"bash -c 'npx tsc --noEmit'"
		]
	},
	"scripts": {
		"start": "VITE_API_URL=http://localhost:8787 vite dev",
		"dev": "wrangler dev --config wrangler.local.jsonc --port 8787 --local",
		"dev:cloudflare": "wrangler dev --config wrangler.dev.jsonc --port 8787",
		"dev:setup": "./scripts/setup-dev.sh",
		"clean": "rimraf dist .wrangler/tmp .wrangler/build .wrangler/cache .wrangler/kv-assets",
		"build": "node scripts/debug-build.mjs",
		"deploy": "npm run build && wrangler deploy --config wrangler.jsonc",
		"deploy:dev": "VITE_API_URL=https://loresmith-ai-dev.oren-t-fisk.workers.dev npm run build && wrangler deploy --config wrangler.dev.jsonc",
		"migrate": "./scripts/migrate.sh",
		"migrate:bootstrap:dev": "./scripts/d1-bootstrap.sh dev",
		"migrate:bootstrap:prod": "./scripts/d1-bootstrap.sh prod",
		"migrate:dev": "wrangler d1 migrations apply loresmith-db-dev --config wrangler.dev.jsonc --remote",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"e2e:server": "VITE_API_URL=http://localhost:8787 npm run build && E2E_SEED_USER=1 ./scripts/e2e-db-setup.sh && wrangler dev --config wrangler.local.jsonc --port 8787 --local",
		"types": "wrangler types",
		"format": "biome check --write .",
		"check": "biome check . && node scripts/check-import-paths.mjs && tsc",
		"check:imports": "node scripts/check-import-paths.mjs",
		"validate": "npm run check && npm run test:coverage",
		"prepare": "husky",
		"wiki:sync": "node scripts/sync-docs-to-wiki.js",
		"wiki:sync:dry-run": "node scripts/sync-docs-to-wiki.js --dry-run",
		"r2:clear": "node scripts/clear-r2.js",
		"r2:clear:dry-run": "node scripts/clear-r2.js --dry-run"
	},
	"keywords": [
		"cloudflare",
		"ai",
		"agents"
	],
	"author": "",
	"license": "MIT",
	"overrides": {
		"youch": "4.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@cloudflare/vite-plugin": "^1.26.1",
		"@cloudflare/vitest-pool-workers": "^0.12.20",
		"@cloudflare/workers-types": "^4.20260307.1",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.1.11",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^25.3.3",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitest/coverage-v8": "^4.0.18",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.3.2",
		"rimraf": "^5.0.10",
		"tailwindcss": "^4.1.11",
		"tsx": "^4.20.4",
		"typescript": "^5.8.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"wrangler": "^4.56.0"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.58",
		"@ai-sdk/openai": "^3.0.41",
		"@ai-sdk/react": "^3.0.118",
		"@ai-sdk/ui-utils": "^1.2.11",
		"@hono/swagger-ui": "^0.6.0",
		"@hono/zod-openapi": "^1.2.2",
		"@phosphor-icons/react": "^2.1.10",
		"@radix-ui/react-avatar": "^1.1.10",
		"@radix-ui/react-dropdown-menu": "^2.1.15",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-switch": "^1.2.5",
		"@types/cytoscape": "^3.31.0",
		"@types/marked": "^6.0.0",
		"agents": "^0.7.2",
		"ai": "^6.0.67",
		"bcryptjs": "^3.0.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cytoscape": "^3.33.1",
		"file-type": "^21.3.0",
		"hono": "^4.12.7",
		"jose": "^6.0.11",
		"lucide-react": "^0.577.0",
		"mammoth": "^1.11.0",
		"marked": "^17.0.4",
		"pdf-lib": "^1.17.1",
		"pdfjs-serverless": "^1.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-joyride": "^2.9.3",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"resend": "^6.9.3",
		"stripe": "^17.7.0",
		"tailwind-merge": "^3.3.1",
		"tslog": "^4.10.2",
		"zod": "^4.3.6"
	}
}
