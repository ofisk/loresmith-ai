# Development Environment Variables Template
# Copy this file to .dev.vars and fill in your actual values
# This file should be added to .gitignore to keep secrets secure

# Cloudflare AI Gateway (optional)
# GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/..

# Local development environment variables
ADMIN_SECRET=your-dev-admin-secret-here
# Default text generation provider key
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Embeddings provider key
OPENAI_API_KEY=your-openai-api-key-here

# Cheap LLM chunk gate before full entity extraction (default off). Set true to skip full extraction on clearly non-substantive chunks.
# EXTRACTION_CHUNK_GATE_ENABLED=true

# JWT signing secret (required for auth - use a random string)
JWT_SECRET=your-jwt-secret-here

# CORS allowed origins (comma-separated list)
# Development origins for local servers
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Google OAuth (required for "Sign in with Google")
# Get client ID and secret from Google Cloud Console. Do not expose client secret to the frontend.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Username/password auth: email verification (optional; leave empty to disable registration emails)
# Resend (https://resend.com) API key for sending verification emails
RESEND_API_KEY=
# Base URL for verification links (e.g. http://localhost:5173 or https://yourapp.com)
APP_ORIGIN=http://localhost:5173
# From address for verification emails (must be verified in Resend)
VERIFICATION_EMAIL_FROM=noreply@yourdomain.com

# Stripe (billing) - use test keys for dev (sk_test_..., price_..., whsec_...)
# See docs/DEPLOYMENT.md for how to obtain test keys and set up the dev webhook
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC_MONTHLY=price_...
# STRIPE_PRICE_BASIC_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_INDEXING_CREDITS_50K=price_...
# STRIPE_PRICE_INDEXING_CREDITS_200K=price_...
# STRIPE_PRICE_INDEXING_CREDITS_500K=price_...
