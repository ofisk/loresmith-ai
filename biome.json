{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/*.js",
			"**/*.jsx",
			"**/*.ts",
			"**/*.tsx",
			"**/*.json",
			"**/*.jsonc",
			"**/*.css",
			"**/*.mjs",
			"!!dist",
			"!!node_modules",
			"!!.wrangler",
			"!!build",
			"!!skills-lock.json",
			"!!.agents",
			"!!.claude",
			"!!.vscode",
			"!!**/worker-configuration.d.ts"
		]
	},
	"formatter": { "enabled": true, "indentStyle": "tab" },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": { "noNonNullAssertion": "off", "useImportType": "error" },
			"complexity": { "noBannedTypes": "off", "noStaticOnlyClass": "off" },
			"correctness": {
				"useExhaustiveDependencies": "warn",
				"noUnusedFunctionParameters": "warn"
			},
			"a11y": { "noLabelWithoutControl": "warn" },
			"suspicious": {
				"noExplicitAny": "off",
				"noConfusingVoidType": "off",
				"noArrayIndexKey": "warn",
				"noConsole": {
					"level": "warn",
					"options": { "allow": [] }
				}
			}
		}
	},
	"javascript": {
		"formatter": { "quoteStyle": "double", "trailingCommas": "es5" }
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["scripts/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": [
				"tests/**",
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/*.spec.ts",
				"**/*.spec.tsx"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["src/agents/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": [
				"src/lib/zod-utils.ts",
				"src/lib/notifications.ts",
				"src/lib/shard-generation-utils.ts",
				"src/dao/file/file-dao.ts",
				"src/dao/dao-factory.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["src/components/shard/PropertyField.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		}
	]
}
